<h1 class="text-3xl font-bold mb-8 text-gray-800">Append Activity</h1>

<div class="bg-white rounded-3xl shadow-xl p-8 max-w-2xl mx-auto">

    <!-- Mode Selector -->
    <div class="flex border-b mb-8">
        <button onclick="switchMode(0)" id="btn-scan"
                class="flex-1 py-4 text-center font-medium border-b-2 border-indigo-600 text-indigo-600">
            📷 Scan QR Code
        </button>
        <button onclick="switchMode(1)" id="btn-manual"
                class="flex-1 py-4 text-center font-medium text-gray-500 hover:text-gray-700">
            🔑 Enter Passkey
        </button>
    </div>

    <!-- SCAN MODE -->
    <div id="scan-mode">
        <div class="mb-6">
            <label class="block text-sm font-medium mb-2">Select User</label>
            <select id="userSelect" class="w-full border rounded-2xl px-5 py-4 text-lg">
                <% users.forEach(user => { %>
                    <option value="<%= user.id %>"><%= user.name %></option>
                <% }); %>
            </select>
        </div>

        <div class="mb-6">
            <label class="block text-sm font-medium mb-3">Scan Your QR Code</label>
            <div id="reader" class="border-4 border-gray-300 rounded-3xl overflow-hidden bg-black relative" 
                 style="height: 420px;"></div>
            
            <p id="scanStatus" class="text-center text-sm mt-4 text-gray-600">
                Hold your QR Code in front of the camera
            </p>
        </div>

        <button onclick="restartScanner()" 
                class="text-indigo-600 hover:text-indigo-700 text-sm font-medium">
            🔄 Restart Camera
        </button>
    </div>

    <!-- MANUAL PASKEY MODE -->
    <div id="manual-mode" class="hidden">
        <div class="mb-6">
            <label class="block text-sm font-medium mb-2">Select User</label>
            <select id="manualUserSelect" class="w-full border rounded-2xl px-5 py-4 text-lg">
                <% users.forEach(user => { %>
                    <option value="<%= user.id %>"><%= user.name %></option>
                <% }); %>
            </select>
        </div>

        <div class="mb-6">
            <label class="block text-sm font-medium mb-2">Enter Your Passkey</label>
            <input type="text" id="manualPasskey" 
                   class="w-full border rounded-2xl px-5 py-4 font-mono text-lg tracking-widest"
                   placeholder="Paste your secret passkey here">
            <p class="text-xs text-gray-500 mt-2">This is the long code inside your QR Code</p>
        </div>
    </div>

    <!-- Activity Form -->
    <form id="activityForm" action="/append" method="POST" class="hidden">
        <input type="hidden" name="user_id" id="userIdField">
        <input type="hidden" name="verification_code" id="secretField">

        <div class="mb-6">
            <label class="block text-sm font-medium mb-2">What did you do?</label>
            <textarea name="description" rows="5" required
                      class="w-full border rounded-2xl px-5 py-4 focus:ring-2 focus:ring-indigo-500"
                      placeholder="Describe your activity today..."></textarea>
        </div>

        <button type="submit"
                class="w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-5 rounded-2xl text-lg transition">
            ✅ Append Activity
        </button>
    </form>
</div>

<!-- QR Scanner Library -->
<script src="https://unpkg.com/html5-qrcode@2.3.8/html5-qrcode.min.js"></script>

<script>
let html5QrCode = null;
let currentMode = 0; // 0 = scan, 1 = manual

function switchMode(mode) {
    currentMode = mode;
    
    document.getElementById('scan-mode').classList.toggle('hidden', mode === 1);
    document.getElementById('manual-mode').classList.toggle('hidden', mode === 0);
    
    document.getElementById('btn-scan').classList.toggle('border-b-2', mode === 0);
    document.getElementById('btn-scan').classList.toggle('border-indigo-600', mode === 0);
    document.getElementById('btn-scan').classList.toggle('text-indigo-600', mode === 0);
    document.getElementById('btn-manual').classList.toggle('border-b-2', mode === 1);
    document.getElementById('btn-manual').classList.toggle('border-indigo-600', mode === 1);
    document.getElementById('btn-manual').classList.toggle('text-indigo-600', mode === 1);

    if (mode === 0) startScanner();
    else if (html5QrCode) html5QrCode.stop();
}

// ====================== QR SCANNER ======================
function startScanner() {
    if (html5QrCode) html5QrCode.clear();
    
    html5QrCode = new Html5Qrcode("reader");

    html5QrCode.start(
        { facingMode: "environment" },
        { 
            fps: 12, 
            qrbox: { width: 280, height: 280 },
            aspectRatio: 1.0 
        },
        (decodedText) => handleSuccessfulScan(decodedText),
        () => {}
    ).catch(err => console.error(err));
}

function handleSuccessfulScan(qrData) {
    if (qrData.startsWith("taskappend://")) {
        const parts = qrData.replace("taskappend://", "").split(":");
        document.getElementById("userIdField").value = parts[0];
        document.getElementById("secretField").value = parts[1];
        document.getElementById("userSelect").value = parts[0];

        document.getElementById("activityForm").classList.remove("hidden");
        document.getElementById("scanStatus").innerHTML = 
            `<span class="text-green-600 font-semibold">✓ QR Code Verified!</span>`;
        
        html5QrCode.stop();
    }
}

function restartScanner() {
    if (html5QrCode) html5QrCode.stop().then(() => startScanner());
}

// ====================== MANUAL MODE ======================
document.getElementById('manualPasskey').addEventListener('input', function() {
    const passkey = this.value.trim();
    const userId = document.getElementById('manualUserSelect').value;

    if (passkey.length > 20) {  // Basic validation
        document.getElementById("userIdField").value = userId;
        document.getElementById("secretField").value = passkey;
        document.getElementById("activityForm").classList.remove("hidden");
    }
});

// Start with Scan mode
window.onload = () => {
    switchMode(0);
};
</script>