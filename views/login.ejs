

<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-md-6">
      <div class="card shadow">
        <div class="card-body p-5">
          <h2 class="text-center mb-4">🔑 Login to TaskAppend</h2>
          <p class="text-center text-muted mb-4">Insert your personal token or scan the QR code</p>

          <% if (error === 'missing') { %>
            <div class="alert alert-danger">Please enter the verification code.</div>
          <% } else if (error === 'invalid') { %>
            <div class="alert alert-danger">Invalid token. Please check and try again.</div>
          <% } %>

          <form action="/login" method="POST">
            <div class="mb-4">
              <label for="verification_code" class="form-label">Your Token / Secret</label>
              <input 
                type="text" 
                class="form-control form-control-lg" 
                id="verification_code" 
                name="verification_code" 
                placeholder="Paste your token here..."
                autocomplete="off"
                required
              >
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100">
              Login for 8 hours
            </button>
          </form>

          <hr class="my-4">
          
          <div class="text-center">
            <small class="text-muted">
              Session will be valid for <strong>8 hours</strong>
            </small>
          </div>
        </div>
      </div>

      <div class="text-center mt-4">
        <a href="/admin" class="text-muted">← Admin Panel</a>
      </div>
    </div>
  </div>
</div>