<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Logora - <%= title || 'Daily Log' %></title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    
    <style>
        .active { 
            @apply border-b-2 border-indigo-600 text-indigo-600 font-semibold; 
        }
    </style>
</head>
<body class="bg-gray-50">

    <!-- Top Navigation -->
    <nav class="bg-white shadow border-b sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex items-center justify-between h-16">
                <div class="flex items-center gap-10">
                    <h1 class="text-2xl font-bold text-indigo-600">Logora</h1>
                    
                    <div class="flex items-center gap-8 text-sm">
                        <a href="/append" class="<%= currentPage === 'append' ? 'active' : 'hover:text-gray-700' %>">
                            <i class="fas fa-plus mr-1"></i> Append Activity
                        </a>
                        <a href="/show" class="<%= currentPage === 'show' ? 'active' : 'hover:text-gray-700' %>">
                            <i class="fas fa-calendar-alt mr-1"></i> View Logs
                        </a>
                        <a href="/admin" class="<%= currentPage === 'admin' ? 'active' : 'hover:text-gray-700' %>">
                            <i class="fas fa-cog mr-1"></i> Admin
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </nav>

    <!-- Page Content -->
    <div class="max-w-7xl mx-auto px-6 py-8">
        <%- body %>
    </div>

</body>
</html>
