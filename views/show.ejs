
        <h1 class="text-3xl font-bold mb-8">View Historical Logs</h1>

        <form method="POST" class="bg-white p-6 rounded-xl shadow mb-10 flex gap-6 items-end">
            <div>
                <label class="block text-sm mb-2">Date</label>
                <input type="date" name="date" value="<%= selectedDate %>" 
                       class="border rounded-lg px-4 py-3">
            </div>
            <div>
                <label class="block text-sm mb-2">User</label>
                <select name="user_id" class="border rounded-lg px-4 py-3">
                    <option value="">All Users</option>
                    <% users.forEach(u => { %>
                        <option value="<%= u.id %>" <%= selectedUser == u.id ? 'selected' : '' %>>
                            <%= u.name %>
                        </option>
                    <% }); %>
                </select>
            </div>
            <button type="submit" 
                    class="bg-indigo-600 text-white px-8 py-3 rounded-lg hover:bg-indigo-700">
                Show Logs
            </button>
        </form>

        <% if (logs.length > 0) { %>
            <div class="space-y-4">
                <% logs.forEach(log => { %>
                    <div class="bg-white p-5 rounded-xl shadow">
                        <div class="flex justify-between items-start">
                            <div>
                                <span class="font-medium"><%= log.user_name %></span>
                                <span class="text-xs text-gray-400 ml-3 font-mono">
                                    <%= new Date(log.created_at).toLocaleString('en-GB', {
                                        day:'2-digit', month:'2-digit', year:'numeric',
                                        hour:'2-digit', minute:'2-digit'
                                    }) %>
                                </span>
                            </div>
                        </div>
                        <p class="mt-3 text-gray-700"><%= log.description %></p>
                    </div>
                <% }); %>
            </div>
        <% } else if (selectedDate || selectedUser) { %>
            <p class="text-gray-500">No logs found for the selected criteria.</p>
        <% } %>
